# MysticEast AI - Environment Variables
# Copy this file to .env.local for local development
# Or configure these in Vercel Dashboard > Project Settings > Environment Variables

# Required: Your OpenAI API Key (or any OpenAI-compatible API key)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom base URL for OpenAI-compatible APIs (e.g., Azure, DeepSeek, Groq)
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
