# MysticEast AI - Environment Variables
# Copy this file to .env.local for local development
# Or configure these in your deployment platform (Vercel, etc.)

# Required: Your DeepSeek API Key
# Get one at: https://platform.deepseek.com/api_keys
OPENAI_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API endpoint (OpenAI-compatible)
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Recommended DeepSeek model
OPENAI_MODEL=deepseek-chat
